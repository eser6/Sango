# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key — get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use. flash-lite has the most generous free-tier daily quota;
# gemini-2.5-flash gives slightly richer replies but a smaller free quota.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional tuning. Higher temperature = warmer / more varied replies.
GEMINI_TEMPERATURE=0.9
GEMINI_MAX_OUTPUT_TOKENS=2048

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:3000

# SQLite database file for conversation history.
DATABASE_PATH=sango.db
